# Database Configuration
DB_NAME=nuhach
DB_USER=admin
DB_PASSWORD=your_secure_password_here
DB_HOST=localhost
DB_PORT=5432

DATABASE_URL=postgresql://admin:your_secure_password_here@localhost:5432/nuhach

# OpenSearch Configuration
OPENSEARCH_INITIAL_ADMIN_PASSWORD=YourSecurePassword123!
OPENSEARCH_JAVA_OPTS=-Xms1g -Xmx1g

# Data Paths
CSV_PATH=./data/processed/dataset_final.csv

# Telegram Bot Token (get from @BotFather)
BOT_API_KEY=1234567890:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Demand-driven store offers
OFFER_CACHE_TTL_HOURS=8
SCRAPER_STORES=Ozon,ЛЭТУАЛЬ,Золотое Яблоко,Рандеву

# OpenRouter fallback for domain-restricted store search and risk comments.
# A funded account is recommended: web search may return HTTP 402 with zero credits.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_MAX_TOKENS=4000
OPENROUTER_MAX_ATTEMPTS=2
OPENROUTER_SITE_URL=https://github.com/merkulovlad/nuhach
